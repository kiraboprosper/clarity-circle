﻿{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": { "rules": "clarity-circle/storage.rules" },
  "functions": [
    {
      "source": "clarity-circle/functions",
      "codebase": "default",
      "disallowLegacyRuntimeConfig": true,
      "ignore": ["node_modules", ".git", "firebase-debug.log", "firebase-debug.*.log", "*.local"]
    }
  ],
  "apphosting": {
    "source": "clarity-circle",
    "region": "us-central1"
  }
}
